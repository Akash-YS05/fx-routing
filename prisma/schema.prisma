generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Rail {
  id                     String        @id @default(cuid())
  code                   String        @unique
  name                   String
  flatFee                Decimal       @db.Decimal(12, 4)
  percentFee             Decimal       @db.Decimal(8, 6)
  fxMarkup               Decimal       @db.Decimal(8, 6)
  avgSettlementTimeHours Decimal       @db.Decimal(8, 2)
  reliabilityScore       Decimal       @db.Decimal(5, 4)
  isActive               Boolean       @default(true)
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt
  transactions           Transaction[]

  @@index([isActive])
}

model Transaction {
  id                       String   @id @default(cuid())
  amount                   Decimal  @db.Decimal(14, 2)
  sourceCurrency           String
  destinationCurrency      String
  priority                 String
  maxTime                  Int?
  maxFeePercent            Decimal? @db.Decimal(8, 4)
  selectedRailCode         String
  selectedRailScore        Decimal  @db.Decimal(10, 6)
  totalCostSource          Decimal  @db.Decimal(14, 4)
  settlementTimeHours      Decimal  @db.Decimal(10, 2)
  explanation              String
  comparisonPayload        Json
  whatIfShockPercent       Decimal? @db.Decimal(6, 3)
  anomalyFlag              Boolean  @default(false)
  platformMarginSource     Decimal  @db.Decimal(14, 4)
  createdAt                DateTime @default(now())
  railId                   String
  rail                     Rail     @relation(fields: [railId], references: [id])

  @@index([createdAt])
  @@index([selectedRailCode])
}

model FxRate {
  id                  String   @id @default(cuid())
  pair                String   @unique
  baseRate            Decimal  @db.Decimal(14, 6)
  lastFluctuatedRate  Decimal  @db.Decimal(14, 6)
  sourceCurrency      String
  destinationCurrency String
  expiresAt           DateTime
  updatedAt           DateTime @updatedAt
  createdAt           DateTime @default(now())

  @@index([expiresAt])
}
